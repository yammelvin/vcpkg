set(program_name lief-patchelf)
if(CMAKE_HOST_SYSTEM_NAME STREQUAL "Linux")
    set(program_version 0.17.6)
    vcpkg_execute_in_download_mode(COMMAND "uname" "-m" OUTPUT_VARIABLE HOST_ARCH OUTPUT_STRIP_TRAILING_WHITESPACE)
    if(HOST_ARCH STREQUAL "x86_64")
        set(patchelf_platform "x86_64")
        set(download_sha512 "7ccf4d18c49452144d6427d54bf13f99c81d3c5dd02a79a7f8f27a5bd5930505638ef7c9fd20c8cddfe8c5408a8f8d6dd03379d9b95d8928180c52143e2f3072")
    elseif(HOST_ARCH MATCHES "i[3-6]86")
        set(patchelf_platform "i686")
        set(download_sha512 "8c71cdf0f017038d02fc3e01d40bc8501b910de904f2731230d0d15727b21e2d32e641c74b3e4421cfcb9c85b3682a1c2d0bbb4854c30c37fd82be689adb08bd")
    elseif(HOST_ARCH STREQUAL "aarch64")
        set(patchelf_platform "aarch64")
        set(download_sha512 "9d8bbafa7f096fb22e36c4ee943dc62fe68460eaf61cbe47696aad90d6bbf2525e04ebca39ccae353030cf97db697fc87f37d5ed98d0d16552d1330278bdb590")
    else()
        return()
    endif()
    set(download_filename "lief-tools-${patchelf_platform}-unknown-linux-gnu.zip")
    set(download_urls "https://github.com/lief-project/LIEF/releases/download/${program_version}/${download_filename}")
    set(tool_subdirectory "${program_version}-${patchelf_platform}-linux")
    set(paths_to_search "${DOWNLOADS}/tools/${program_name}/${tool_subdirectory}/bin")
    set(post_install_command chmod +x "${DOWNLOADS}/tools/${program_name}/${tool_subdirectory}/bin/${program_name}")
    message(status ${post_install_command})
elseif(CMAKE_HOST_SYSTEM_NAME STREQUAL "Windows")
    set(patchelf_host "win32")
    set(program_version 0.17.6)
    set(download_sha512 "a5daff8baa0768969975931279bccc79f425cd44f1fd4aaf70b8ace83bb17c34070d9469da02222e36895567034536002b12077207b37320402d0e595ab1e458")
    set(download_filename "lief-tools-${patchelf_platform}-pc-windows-msvc.zip")
    set(download_urls "https://github.com/lief-project/LIEF/releases/download/${program_version}/${download_filename}")
    set(tool_subdirectory "${program_version}-${patchelf_platform}-${patchelf_host}")
    set(paths_to_search "${DOWNLOADS}/tools/${program_name}/${tool_subdirectory}/bin")
endif()
